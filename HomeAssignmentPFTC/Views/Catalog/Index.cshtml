@model IEnumerable<HomeAssignmentPFTC.Models.CatalogItemViewModel>

@{
    ViewData["Title"] = "Menu Catalogue";
}

<div class="container mt-5">
    <h2 class="mb-4">Menu Catalogue</h2>

    <div class="row g-3 mb-5 fade-in-up">
        <div class="col-md-8">
            <input type="text" id="searchInput" class="form-control form-control-lg glass-input shadow-sm" placeholder="Start typing to live-search dishes (e.g., Pasta, Burger)..." />
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" asp-route-sortOrder="@ViewData["PriceSortParam"]" class="btn glass-button btn-lg w-100 h-100 d-flex align-items-center justify-content-center shadow-sm">
                Sort by Price ↕
            </a>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4" id="catalogGrid">
        
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted mt-5 fade-in-up">
                <p class="fs-5">No completed menus found. Check back later!</p>
            </div>
        }
        
        @{ int delayCounter = 1; }
        @foreach (var item in Model)
        {
            string currentDelay = $"delay-{(delayCounter % 5) + 1}";
            delayCounter++;

            <div class="col menu-card">
                <div class="card h-100 glass-panel fade-in-up @currentDelay border-0 bg-transparent">
                    <div class="card-body">
                        <h5 class="card-title text-dark fw-bold fs-4 dish-name mb-1">@item.ItemName</h5>
                        <h6 class="card-subtitle mb-4 text-primary fs-5 fw-bold">@item.DisplayPrice</h6>
                        <p class="card-text text-muted small mb-0 d-flex align-items-center">
                            <i class="bi bi-shop me-2"></i> @item.RestaurantName
                            <span class="badge bg-dark bg-opacity-75 ms-auto rounded-pill px-3">@item.Locality</span>
                        </p>
                    </div>
                    
                    <div class="card-footer bg-transparent border-top-0 pt-0 pb-3">
                        <div class="input-group input-group-sm shadow-sm rounded-3">
                            <select class="form-select glass-input border-end-0 target-lang">
                                <option value="" disabled selected>Translate to...</option>
                                <option value="en">English</option>
                                <option value="it">Italian</option>
                                <option value="fr">French</option>
                                <option value="de">German</option>
                                <option value="es">Spanish</option>
                                <option value="ja">Japanese</option>
                            </select>
                            <button class="btn glass-button px-4 translate-btn" type="button" data-original-text="@item.ItemName">Translate</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const menuCards = document.querySelectorAll('.menu-card');
            
            menuCards.forEach(card => {
                const dishName = card.querySelector('.dish-name').innerText.toLowerCase();
                
                if (dishName.includes(searchTerm)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });

        document.querySelectorAll('.translate-btn').forEach(button => {
            button.addEventListener('click', async function() {
                const originalText = this.getAttribute('data-original-text');
                const targetLanguage = this.previousElementSibling.value;
                const dishNameElement = this.closest('.card').querySelector('.dish-name');

                // Validates that the user has actually selected a language!
                if (!targetLanguage) {
                    alert("Please select a language from the drop-down first.");
                    return;
                }

                const originalButtonText = this.innerText;
                this.innerText = "...";
                this.disabled = true;

                try {
                    const response = await fetch('/Catalog/TranslateItem', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ text: originalText, targetLanguage: targetLanguage })
                    });

                    if (response.ok) {
                        const data = await response.json();
                        dishNameElement.innerText = data.translatedText;
                        console.log(`Translation loaded from: ${data.source}`);
                    } else {
                        alert("Translation failed. Please try again.");
                    }
                } catch (error) {
                    console.error("Error:", error);
                } finally {
                    this.innerText = originalButtonText;
                    this.disabled = false;
                }
            });
        });
    </script>
}