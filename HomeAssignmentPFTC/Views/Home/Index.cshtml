@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-lg-8 py-5">
            <h1 class="display-4 fw-bold mb-4" style="color: #111827;">Transform Physical Menus into Digital Data</h1>
            <p class="lead text-muted mb-5 px-md-5" style="line-height: 1.8;">
                Utilise advanced Cloud AI to seamlessly upload physical menu images and convert them into highly searchable, structural data in seconds.
            </p>
            <a asp-controller="Menu" asp-action="Index" class="btn btn-primary btn-lg shadow-sm px-5 py-3">
                Start Digitising Menus
            </a>
        </div>
    </div>
</div>