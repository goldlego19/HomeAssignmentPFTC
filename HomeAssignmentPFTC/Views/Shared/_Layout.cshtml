<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Menu Platform</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    </head>
<body>
<header class="sticky-top">
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light glass-nav mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" asp-area="" asp-controller="Home" asp-action="Index">🍽️ SmartMenus AI</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1 ms-3">
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-medium px-3" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-medium px-3" asp-area="" asp-controller="Menu" asp-action="Index">Upload Menus</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-medium px-3" asp-area="" asp-controller="Catalog" asp-action="Index">Catalogue</a>
                    </li>
                </ul>

                <ul class="navbar-nav align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                    <li class="nav-item me-4 d-none d-md-block">
                        <span class="text-dark fw-medium small opacity-75">Hello, @User.Identity.Name</span>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-danger btn-sm rounded-pill px-4 fw-bold bg-white bg-opacity-50" asp-controller="Account" asp-action="Logout">Log out</a>
                    </li>
                    }
                    else
                    {
                    <li class="nav-item">
                        <a class="btn glass-button btn-sm rounded-pill px-4" asp-controller="Account" asp-action="Login">Sign in with Google</a>
                    </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container d-flex flex-column flex-grow-1">
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>
</div>

<footer class="glass-nav text-muted py-4 mt-auto">
    <div class="container text-center text-dark fw-medium small">
        &copy; 2026 - PFTC Restaurant Catalog
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>